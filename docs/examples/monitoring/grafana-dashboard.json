{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for rig-seed metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Evolution metrics for rig-seed projects",
  "editable": true,
  "id": null,
  "title": "rig-seed Evolution Dashboard",
  "uid": "rigseed-evolution",
  "tags": ["rigseed", "evolution", "gas-town"],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(rigseed_session_counter, project)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Session Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_session_counter{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "yellow" },
              { "value": 5, "color": "green" },
              { "value": 20, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "title": "Day Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_day_count{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "title": "Roadmap Completion",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_roadmap_pct{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Total Commits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_total_commits{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "title": "Learnings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_learnings_count{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "title": "Sessions Per Week",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_sessions_per_week{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "sessions/wk"
        }
      }
    },
    {
      "title": "Session Count Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_session_counter{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Roadmap Progress Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_roadmap_checked{project=~\"$project\"}",
          "legendFormat": "{{project}} completed"
        },
        {
          "expr": "rigseed_roadmap_unchecked{project=~\"$project\"}",
          "legendFormat": "{{project}} remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Codebase Size Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_total_lines{project=~\"$project\"}",
          "legendFormat": "{{project}} lines"
        },
        {
          "expr": "rigseed_files_in_repo{project=~\"$project\"}",
          "legendFormat": "{{project}} files"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Commits Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rigseed_total_commits{project=~\"$project\"}",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
